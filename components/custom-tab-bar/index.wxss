/* 自定义底部导航栏 - 温暖治愈风 */

.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 140rpx;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
  display: flex;
  justify-content: center;
}

.tab-bar-bg {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 100%;
  height: 120rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 0.95) 20%, #ffffff 100%);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}

.tab-item {
  position: relative;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 10rpx 0;
  transition: all 0.3s ease;
  z-index: 1;
}

.tab-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 6rpx;
  background: transparent;
  transition: all 0.3s ease;
}

.tab-item.active .tab-icon {
  background: linear-gradient(135deg, #fff5f5 0%, #ffe4e8 100%);
  box-shadow: 0 4rpx 20rpx rgba(255, 143, 163, 0.3);
  transform: scale(1.1);
}

.emoji {
  font-size: 44rpx;
  line-height: 1;
  transition: all 0.3s ease;
}

.tab-item.active .emoji {
  transform: scale(1.15);
  filter: drop-shadow(0 2rpx 4rpx rgba(255, 143, 163, 0.4));
}

.tab-text {
  font-size: 24rpx;
  color: #9a8a82;
  font-weight: 500;
  transition: all 0.3s ease;
  margin-top: 4rpx;
}

.tab-item.active .tab-text {
  color: #ff8fa3;
  font-weight: 600;
}

.active-dot {
  position: absolute;
  bottom: 18rpx;
  width: 8rpx;
  height: 8rpx;
  background: linear-gradient(135deg, #ff8fa3 0%, #ff6b7a 100%);
  border-radius: 50%;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
    opacity: 1;
  }
  50% {
    transform: scale(1.3);
    opacity: 0.7;
  }
}

/* 悬浮效果 - 选中项略微上浮 */
.tab-item.active {
  transform: translateY(-8rpx);
}

/* 按下效果 */
.tab-item:active {
  opacity: 0.8;
  transform: scale(0.95);
}

.tab-item.active:active {
  transform: translateY(-4rpx) scale(0.98);
}
