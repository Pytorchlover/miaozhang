/** AI记账小程序 - 全局样式（治愈可爱风） **/

/* 主题色变量 */
page {
  --primary-pink: #ff8fa3;
  --primary-pink-dark: #ff6b7a;
  --primary-pink-light: #ffb6c1;
  --bg-warm: #fef9f3;
  --bg-warm-dark: #f5f0eb;
  --text-primary: #5a4a42;
  --text-secondary: #9a8a82;
  --text-hint: #bbb;
  --success-green: #52c41a;
  --warning-red: #ff6b7a;

  height: 100%;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  background: linear-gradient(180deg, #fef9f3 0%, #f5f0eb 100%);
  font-size: 28rpx;
  color: var(--text-primary);
}

/* 安全区域 */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 全局滚动条样式 */
::-webkit-scrollbar {
  display: none;
}

/* 通用卡片样式 */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin: 16rpx;
  box-shadow: 0 8rpx 30rpx rgba(255, 143, 163, 0.12);
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, #ff8fa3 0%, #ff6b7a 100%);
  color: #ffffff;
  border: none;
  border-radius: 44rpx;
  padding: 20rpx 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 15rpx rgba(255, 107, 122, 0.3);
}

.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-default {
  background: #ffffff;
  color: var(--primary-pink);
  border: 2rpx solid var(--primary-pink);
  border-radius: 44rpx;
  padding: 18rpx 48rpx;
  font-size: 32rpx;
}

/* 输入框样式 */
.input {
  background: #fef9f3;
  border: 2rpx solid #f5ebe6;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
}

.input:focus {
  border-color: var(--primary-pink-light);
}
