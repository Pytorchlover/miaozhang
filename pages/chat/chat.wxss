/* 聊天页面样式 - 可爱猫咪治愈风 */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(180deg, #fef9f3 0%, #fff5f5 100%);
  box-sizing: border-box;
  overflow: hidden;
}

/* 无用的间隔 */
.input-spacing {
  height: 0;
  flex-shrink: 0;
}

/* ==================== 欢迎区域 ==================== */
.welcome-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 40rpx 50rpx;
  animation: fadeIn 0.6s ease-out;
  position: relative;
  overflow: hidden;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 背景装饰 - 模糊的爱心 */
.welcome-bg-hearts {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  overflow: hidden;
}

.bg-heart {
  position: absolute;
  font-size: 40rpx;
  opacity: 0.15;
  animation: floatHeart 6s ease-in-out infinite;
}

.bg-heart:nth-child(1) { left: 10%; top: 15%; animation-delay: 0s; }
.bg-heart:nth-child(2) { right: 15%; top: 25%; animation-delay: 1s; font-size: 30rpx; }
.bg-heart:nth-child(3) { left: 20%; bottom: 30%; animation-delay: 2s; }
.bg-heart:nth-child(4) { right: 10%; bottom: 20%; animation-delay: 3s; font-size: 35rpx; }

@keyframes floatHeart {
  0%, 100% { transform: translateY(0) rotate(-10deg); }
  50% { transform: translateY(-20rpx) rotate(10deg); }
}

/* 猫咪吉祥物容器 */
.cat-mascot {
  position: relative;
  width: 240rpx;
  height: 240rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
  animation: gentleBounce 3s ease-in-out infinite;
}

@keyframes gentleBounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

/* 猫咪身体 - 圆形毛茸茸 */
.cat-body {
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  background: linear-gradient(145deg, #ffffff 0%, #fff5f5 50%, #ffe4e8 100%);
  border-radius: 50%;
  box-shadow:
    0 20rpx 60rpx rgba(255, 143, 163, 0.25),
    inset 0 -10rpx 30rpx rgba(255, 182, 193, 0.3),
    inset 0 10rpx 30rpx rgba(255, 255, 255, 0.8);
}

/* 猫咪头部 */
.cat-head {
  position: relative;
  width: 160rpx;
  height: 140rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fff8f8 100%);
  border-radius: 50% 50% 45% 45%;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 5rpx 20rpx rgba(0, 0, 0, 0.05);
}

/* 猫咪耳朵 */
.cat-ears {
  position: absolute;
  top: -20rpx;
  width: 160rpx;
  display: flex;
  justify-content: space-between;
}

.cat-ear {
  width: 50rpx;
  height: 50rpx;
  background: linear-gradient(180deg, #fff5f5 0%, #ffe4e8 100%);
  border-radius: 50% 50% 20% 20%;
  transform: rotate(0deg);
  box-shadow: inset 0 5rpx 15rpx rgba(255, 143, 163, 0.3);
}

.cat-ear.left { transform: rotate(-15deg); }
.cat-ear.right { transform: rotate(15deg); }

.cat-ear-inner {
  width: 25rpx;
  height: 25rpx;
  background: linear-gradient(180deg, #ffb6c1 0%, #ff8fa3 100%);
  border-radius: 50% 50% 20% 20%;
  margin: 8rpx auto;
}

.cat-ear.right .cat-ear-inner {
  margin: 8rpx auto;
}

/* 猫咪脸部 - 眼睛 */
.cat-eyes {
  display: flex;
  gap: 35rpx;
  margin-top: 10rpx;
  margin-bottom: 8rpx;
}

.cat-eye {
  width: 28rpx;
  height: 32rpx;
  background: linear-gradient(180deg, #4a4a4a 0%, #2a2a2a 100%);
  border-radius: 50%;
  position: relative;
  animation: blink 4s ease-in-out infinite;
}

.cat-eye::before {
  content: '';
  position: absolute;
  width: 10rpx;
  height: 10rpx;
  background: white;
  border-radius: 50%;
  top: 6rpx;
  left: 5rpx;
}

.cat-eye::after {
  content: '';
  position: absolute;
  width: 5rpx;
  height: 5rpx;
  background: white;
  border-radius: 50%;
  bottom: 8rpx;
  right: 6rpx;
  opacity: 0.6;
}

@keyframes blink {
  0%, 90%, 100% { transform: scaleY(1); }
  95% { transform: scaleY(0.1); }
}

/* 猫咪鼻子和嘴巴 */
.cat-nose {
  width: 12rpx;
  height: 10rpx;
  background: #ffb6c1;
  border-radius: 50% 50% 40% 40%;
  margin-bottom: 4rpx;
}

.cat-mouth {
  width: 30rpx;
  height: 15rpx;
  border-bottom: 3rpx solid #ffb6c1;
  border-radius: 0 0 50% 50%;
}

/* 猫咪腮红 */
.cat-blush {
  position: absolute;
  width: 35rpx;
  height: 20rpx;
  background: rgba(255, 182, 193, 0.5);
  border-radius: 50%;
  top: 65rpx;
}

.cat-blush.left { left: 8rpx; }
.cat-blush.right { right: 8rpx; }

/* 猫咪蝴蝶结 */
.cat-bow {
  position: absolute;
  top: -5rpx;
  right: 15rpx;
  z-index: 3;
}

.cat-bow-center {
  width: 16rpx;
  height: 16rpx;
  background: #ff6b7a;
  border-radius: 50%;
  position: relative;
  z-index: 2;
  box-shadow: 0 2rpx 5rpx rgba(0, 0, 0, 0.1);
}

.cat-bow-left, .cat-bow-right {
  position: absolute;
  width: 24rpx;
  height: 18rpx;
  background: linear-gradient(135deg, #ff8fa3 0%, #ff6b7a 100%);
  border-radius: 50% 50% 50% 50%;
  top: -1rpx;
}

.cat-bow-left {
  right: 14rpx;
  transform: rotate(-20deg);
}

.cat-bow-right {
  left: 14rpx;
  transform: rotate(20deg);
}

/* 猫咪爪子 */
.cat-paws {
  position: absolute;
  bottom: -10rpx;
  display: flex;
  gap: 80rpx;
  z-index: 1;
}

.cat-paw {
  width: 40rpx;
  height: 25rpx;
  background: linear-gradient(180deg, #ffe4e8 0%, #ffd0d8 100%);
  border-radius: 50% 50% 40% 40%;
  box-shadow: 0 3rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* 漂浮装饰元素 */
.floating-elements {
  position: absolute;
  width: 280rpx;
  height: 280rpx;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  pointer-events: none;
}

/* 金币 */
.floating-coin {
  position: absolute;
  font-size: 32rpx;
  animation: floatCoin 3s ease-in-out infinite;
  filter: drop-shadow(0 5rpx 10rpx rgba(0, 0, 0, 0.1));
}

.coin-1 { top: 5%; right: 5%; animation-delay: 0s; }
.coin-2 { bottom: 15%; left: 0%; animation-delay: 1s; }
.coin-3 { top: 20%; left: 5%; animation-delay: 0.5s; font-size: 26rpx; }

@keyframes floatCoin {
  0%, 100% { transform: translateY(0) rotate(0deg); opacity: 0.9; }
  50% { transform: translateY(-15rpx) rotate(15deg); opacity: 1; }
}

/* 星星 */
.floating-star {
  position: absolute;
  font-size: 24rpx;
  animation: twinkle 2s ease-in-out infinite;
}

.star-1 { top: 10%; left: 15%; animation-delay: 0.2s; }
.star-2 { bottom: 25%; right: 10%; animation-delay: 0.7s; }
.star-3 { top: 35%; right: 0%; animation-delay: 1.2s; font-size: 20rpx; }

@keyframes twinkle {
  0%, 100% { transform: scale(0.8) rotate(0deg); opacity: 0.5; }
  50% { transform: scale(1.2) rotate(20deg); opacity: 1; }
}

/* 小爱心 */
.floating-heart {
  position: absolute;
  font-size: 20rpx;
  animation: heartFloat 4s ease-in-out infinite;
}

.heart-1 { top: 50%; left: 0%; animation-delay: 0s; }
.heart-2 { bottom: 10%; right: 15%; animation-delay: 1.5s; }
.heart-3 { top: 5%; left: 30%; animation-delay: 2.5s; font-size: 16rpx; }

@keyframes heartFloat {
  0%, 100% { transform: translateY(0) scale(1); opacity: 0.6; }
  50% { transform: translateY(-10rpx) scale(1.1); opacity: 0.9; }
}

/* 欢迎文字 */
.welcome-text {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 50rpx;
  padding: 0 20rpx;
}

.welcome-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #5a4a42;
  margin-bottom: 16rpx;
}

.welcome-subtitle {
  font-size: 26rpx;
  color: #8a7a72;
  text-align: center;
  line-height: 1.8;
}

/* 快捷操作按钮 */
.quick-actions {
  display: flex;
  gap: 24rpx;
  width: 100%;
  margin-bottom: 50rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 20rpx;
  border-radius: 24rpx;
  transition: transform 0.2s, box-shadow 0.2s;
}

.action-btn:active {
  transform: scale(0.95);
}

.action-btn.primary {
  background: linear-gradient(135deg, #ff8fa3 0%, #ff6b7a 100%);
  box-shadow: 0 8rpx 25rpx rgba(255, 107, 122, 0.3);
}

.action-btn.secondary {
  background: #ffffff;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.action-text {
  font-size: 28rpx;
  font-weight: 500;
}

.action-btn.primary .action-text {
  color: #ffffff;
}

.action-btn.secondary .action-text {
  color: #5a4a42;
}

/* 示例提示 */
.example-hints {
  width: 100%;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.05);
}

.hint-label {
  display: block;
  font-size: 24rpx;
  color: #9a8a82;
  margin-bottom: 16rpx;
}

.hint-item {
  font-size: 26rpx;
  color: #5a4a42;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f5f0eb;
}

.hint-item:last-child {
  border-bottom: none;
}

/* ==================== 消息列表 ==================== */
.message-list {
  flex: none;
  height: calc(100vh - 280rpx);
  padding: 24rpx;
  box-sizing: border-box;
}

.message {
  display: flex;
  margin-bottom: 32rpx;
  align-items: flex-start;
  animation: messageIn 0.3s ease-out;
}

@keyframes messageIn {
  from { opacity: 0; transform: translateY(15rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.user-message {
  flex-direction: row-reverse;
}

.ai-message {
  flex-direction: row;
}

.message-content {
  max-width: 72%;
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  word-break: break-word;
  line-height: 1.6;
}

.user-message .message-content {
  background: linear-gradient(135deg, #ff8fa3 0%, #ff6b7a 100%);
  color: #ffffff;
  border-bottom-right-radius: 8rpx;
  margin-right: 16rpx;
  box-shadow: 0 4rpx 15rpx rgba(255, 107, 122, 0.3);
}

.ai-content {
  background: #ffffff;
  border-bottom-left-radius: 8rpx;
  margin-left: 16rpx;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.05);
}

.message-image {
  max-width: 100%;
  border-radius: 16rpx;
  margin-top: 12rpx;
}

/* 头像 */
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: bold;
  flex-shrink: 0;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.1);
}

.user-avatar {
  background: linear-gradient(135deg, #ff8fa3 0%, #ff6b7a 100%);
  color: #ffffff;
}

.ai-avatar {
  background: linear-gradient(135deg, #fff5f5 0%, #ffe4e8 100%);
  border: 3rpx solid #ffb6c1;
}

.avatar-icon {
  font-size: 44rpx;
}

/* ==================== 确认卡片 ==================== */
.confirm-card {
  margin-top: 20rpx;
  background: #fef9f3;
  border-radius: 20rpx;
  padding: 24rpx;
  border: 2rpx solid #ffe4e8;
}

.confirm-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-weight: 600;
  font-size: 28rpx;
  color: #ff6b7a;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #ffe4e8;
}

.confirm-icon {
  font-size: 32rpx;
}

.confirm-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.confirm-item {
  display: flex;
  flex-direction: column;
  background: #ffffff;
  padding: 16rpx;
  border-radius: 12rpx;
}

.confirm-item .label {
  font-size: 22rpx;
  color: #9a8a82;
  margin-bottom: 6rpx;
}

.confirm-item .value {
  font-size: 28rpx;
  color: #5a4a42;
  font-weight: 500;
}

.confirm-item .value.amount {
  color: #ff6b7a;
  font-size: 32rpx;
}

.confirm-item .value.category {
  color: #ff8fa3;
}

.confirm-actions {
  display: flex;
  gap: 20rpx;
}

.btn-confirm, .btn-cancel {
  flex: 1;
  border: none;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 20rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-confirm {
  background: linear-gradient(135deg, #ff8fa3 0%, #ff6b7a 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 15rpx rgba(255, 107, 122, 0.3);
}

.btn-cancel {
  background: #ffffff;
  color: #9a8a82;
  border: 2rpx solid #e8e0da;
}

/* ==================== 加载状态 ==================== */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx;
  gap: 16rpx;
}

.loading-dots {
  display: flex;
  gap: 8rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  background: #ff8fa3;
  border-radius: 50%;
  animation: bounceDot 1.4s ease-in-out infinite;
}

.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes bounceDot {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.5; }
  40% { transform: scale(1); opacity: 1; }
}

.loading text {
  font-size: 24rpx;
  color: #9a8a82;
}

/* ==================== 输入区域 ==================== */
.input-area {
  background: #ffffff;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f5f0eb;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.03);
}

.input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.image-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffb6c1 0%, #ff8fa3 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: #ffffff;
  flex-shrink: 0;
  box-shadow: 0 4rpx 15rpx rgba(255, 143, 163, 0.4);
  transition: transform 0.2s;
}

.image-btn:active {
  transform: scale(0.92);
}

.chat-input {
  flex: 1;
  background: #fef9f3;
  border-radius: 40rpx;
  padding: 22rpx 32rpx;
  font-size: 28rpx;
  border: 2rpx solid #f5f0eb;
  transition: border-color 0.2s;
}

.chat-input:focus {
  border-color: #ffb6c1;
}

.send-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff8fa3 0%, #ff6b7a 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
  box-shadow: 0 4rpx 15rpx rgba(255, 107, 122, 0.3);
  transition: transform 0.2s, opacity 0.2s;
}

.send-btn[disabled] {
  background: #e8e0da;
  box-shadow: none;
}

.send-btn:not([disabled]):active {
  transform: scale(0.92);
}

.send-icon {
  font-size: 28rpx;
  color: #ffffff;
  margin-left: 6rpx;
}

/* 底部留白 - 给自定义 tabBar 留空间 */
.bottom-spacing {
  height: 160rpx;
  width: 100%;
}
