<!-- 设置页面 -->
<view class="container">
  <!-- 小猫吉祥物 -->
  <view class="mascot-section">
    <view class="cat-mascot">
      <!-- 漂浮装饰 -->
      <view class="floating-elements">
        <text class="floating-coin coin-1">💰</text>
        <text class="floating-coin coin-2">✨</text>
        <text class="floating-coin coin-3">💎</text>
        <text class="floating-star star-1">⭐</text>
        <text class="floating-star star-2">✨</text>
        <text class="floating-star star-3">⭐</text>
        <text class="floating-heart heart-1">💕</text>
        <text class="floating-heart heart-2">💗</text>
        <text class="floating-heart heart-3">💖</text>
      </view>

      <!-- 猫咪身体 -->
      <view class="cat-body"></view>

      <!-- 猫咪头部 -->
      <view class="cat-head">
        <!-- 耳朵 -->
        <view class="cat-ears">
          <view class="cat-ear left">
            <view class="cat-ear-inner"></view>
          </view>
          <view class="cat-ear right">
            <view class="cat-ear-inner"></view>
          </view>
        </view>

        <!-- 眼睛 -->
        <view class="cat-eyes">
          <view class="cat-eye"></view>
          <view class="cat-eye"></view>
        </view>

        <!-- 鼻子和嘴巴 -->
        <view class="cat-nose"></view>
        <view class="cat-mouth"></view>

        <!-- 腮红 -->
        <view class="cat-blush left"></view>
        <view class="cat-blush right"></view>

        <!-- 蝴蝶结 -->
        <view class="cat-bow">
          <view class="cat-bow-left"></view>
          <view class="cat-bow-center"></view>
          <view class="cat-bow-right"></view>
        </view>
      </view>

      <!-- 爪子 -->
      <view class="cat-paws">
        <view class="cat-paw"></view>
        <view class="cat-paw"></view>
      </view>
    </view>
    <text class="mascot-text">记账小助手设置</text>
  </view>

  <!-- API配置 -->
  <view class="section">
    <view class="section-header">
      <text class="section-emoji">🔑</text>
      <text class="section-title">API 配置</text>
    </view>
    <view class="setting-card">
      <view class="setting-item">
        <view class="setting-label-row">
          <text class="setting-icon">🤖</text>
          <text class="setting-label">DeepSeek API Key</text>
        </view>
        <input
          type="text"
          class="setting-input"
          placeholder="请输入API Key"
          value="{{apiKey}}"
          bindinput="onApiKeyInput"
        />
      </view>
    </view>
    <view class="setting-hint">
      <text class="hint-icon">💡</text>
      用于AI智能记账，请在
      <text class="link" bindtap="openDeepSeek">DeepSeek官网</text>
      申请
    </view>
  </view>

  <!-- 预警阈值设置 -->
  <view class="section">
    <view class="section-header">
      <text class="section-emoji">🎯</text>
      <text class="section-title">预警阈值</text>
      <view class="mode-toggle" bindtap="toggleThresholdMode">
        <text class="mode-text">{{isManualMode ? '手动设置' : '自动计算'}}</text>
      </view>
    </view>

    <!-- 自动模式：根据月收入计算 -->
    <view wx:if="{{!isManualMode}}" class="setting-card">
      <view class="setting-item">
        <view class="setting-label-row">
          <text class="setting-icon">💰</text>
          <text class="setting-label">月收入</text>
        </view>
        <view class="input-with-unit">
          <text class="unit">¥</text>
          <input
            type="digit"
            class="setting-input amount-input"
            placeholder="请输入月收入"
            value="{{monthlyIncome}}"
            bindinput="onIncomeInput"
          />
        </view>
      </view>
    </view>

    <!-- 手动模式：直接设置阈值 -->
    <view wx:if="{{isManualMode}}" class="setting-card">
      <view class="setting-item">
        <view class="setting-label-row">
          <text class="setting-icon">📅</text>
          <text class="setting-label">日预警</text>
        </view>
        <view class="input-with-unit">
          <text class="unit">¥</text>
          <input
            type="digit"
            class="setting-input amount-input"
            placeholder="0.00"
            value="{{dailyThreshold}}"
            bindinput="onDailyThresholdInput"
          />
        </view>
      </view>
      <view class="setting-item">
        <view class="setting-label-row">
          <text class="setting-icon">📆</text>
          <text class="setting-label">周预警</text>
        </view>
        <view class="input-with-unit">
          <text class="unit">¥</text>
          <input
            type="digit"
            class="setting-input amount-input"
            placeholder="0.00"
            value="{{weeklyThreshold}}"
            bindinput="onWeeklyThresholdInput"
          />
        </view>
      </view>
      <view class="setting-item">
        <view class="setting-label-row">
          <text class="setting-icon">🗓️</text>
          <text class="setting-label">月预警</text>
        </view>
        <view class="input-with-unit">
          <text class="unit">¥</text>
          <input
            type="digit"
            class="setting-input amount-input"
            placeholder="0.00"
            value="{{monthlyThreshold}}"
            bindinput="onMonthlyThresholdInput"
          />
        </view>
      </view>
    </view>

    <!-- 阈值说明卡片 -->
    <view class="threshold-info-card">
      <view class="info-icon">💡</view>
      <view class="info-content">
        <text class="info-title">{{isManualMode ? '手动设置模式' : '自动计算模式'}}</text>
        <text class="info-desc">{{isManualMode ? '直接设置每日/每周/每月的最大消费额度' : '根据月收入自动计算：日=5%, 周=20%, 月=50%'}}</text>
      </view>
    </view>
  </view>

  <!-- 消息订阅 -->
  <view class="section">
    <view class="section-header">
      <text class="section-emoji">🔔</text>
      <text class="section-title">通知设置</text>
    </view>
    <view class="setting-card">
      <view class="setting-item" bindtap="requestSubscribe">
        <view class="setting-label-row">
          <text class="setting-icon">📬</text>
          <text class="setting-label">订阅预警消息</text>
        </view>
        <view class="toggle-btn {{subscribed ? 'active' : ''}}">
          <view class="toggle-circle"></view>
        </view>
      </view>
    </view>
    <view class="setting-hint">
      <text class="hint-icon">💡</text>
      当支出超过阈值时，AI会通过微信推送提醒你
    </view>
  </view>

  <!-- 保存按钮 -->
  <button class="save-btn" bindtap="saveSettings">
    <text class="btn-icon">✓</text>
    <text>保存设置</text>
  </button>

  <!-- 版本信息 -->
  <view class="version">
    <text>AI记账 v1.0.0</text>
    <text class="version-divider">•</text>
    <text>Made with 💕</text>
  </view>
</view>

<!-- 自定义底部导航 - 放在 container 外面因为是 fixed 定位 -->
<custom-tab-bar current="settings"></custom-tab-bar>
