/* 设置页面样式 - 治愈可爱风 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #fef9f3 0%, #f5f0eb 100%);
  padding: 24rpx;
  padding-bottom: 120rpx;
  box-sizing: border-box;
}

/* ==================== 小猪吉祥物区域 ==================== */
.mascot-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 30rpx;
}

.mascot {
  font-size: 100rpx;
  margin-bottom: 16rpx;
  animation: bounce 2s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-15rpx); }
}

.mascot-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #5a4a42;
}

/* ==================== 区块 ==================== */
.section {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 30rpx rgba(255, 143, 163, 0.12);
}

.section-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.section-emoji {
  font-size: 36rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #5a4a42;
}

/* ==================== 设置卡片 ==================== */
.setting-card {
  background: #fef9f3;
  border-radius: 20rpx;
  padding: 8rpx 20rpx;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5ebe6;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-label-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.setting-icon {
  font-size: 32rpx;
}

.setting-label {
  font-size: 28rpx;
  color: #5a4a42;
}

.setting-input {
  text-align: right;
  font-size: 28rpx;
  color: #5a4a42;
  flex: 1;
  margin-left: 16rpx;
}

.setting-hint {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  font-size: 24rpx;
  color: #9a8a82;
  margin-top: 16rpx;
  line-height: 1.6;
}

.hint-icon {
  font-size: 24rpx;
  flex-shrink: 0;
}

.link {
  color: #ff8fa3;
}

.input-with-unit {
  display: flex;
  align-items: center;
}

.unit {
  font-size: 28rpx;
  color: #9a8a82;
  margin-right: 8rpx;
}

.amount-input {
  text-align: right;
}

/* ==================== 开关按钮 ==================== */
.toggle-btn {
  width: 88rpx;
  height: 48rpx;
  background: #e8e0da;
  border-radius: 24rpx;
  position: relative;
  transition: background 0.3s;
}

.toggle-btn.active {
  background: linear-gradient(135deg, #ff8fa3 0%, #ff6b7a 100%);
}

.toggle-circle {
  width: 40rpx;
  height: 40rpx;
  background: #ffffff;
  border-radius: 50%;
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  transition: transform 0.3s;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.toggle-btn.active .toggle-circle {
  transform: translateX(40rpx);
}

/* ==================== 阈值预览 ==================== */
.threshold-preview {
  margin-top: 24rpx;
  background: linear-gradient(135deg, #fff5f5 0%, #ffe4e8 100%);
  border-radius: 20rpx;
  padding: 24rpx;
}

.threshold-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.threshold-emoji {
  font-size: 28rpx;
}

.threshold-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #ff6b7a;
}

.threshold-grid {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
}

.threshold-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 16rpx 8rpx;
}

.threshold-badge {
  width: 40rpx;
  height: 40rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 10rpx;
}

.threshold-badge.daily {
  background: linear-gradient(135deg, #ffb6c1 0%, #ff8fa3 100%);
}

.threshold-badge.weekly {
  background: linear-gradient(135deg, #ffd6cc 0%, #ffb3a0 100%);
}

.threshold-badge.monthly {
  background: linear-gradient(135deg, #ff8fa3 0%, #ff6b7a 100%);
}

.threshold-value {
  font-size: 24rpx;
  font-weight: 600;
  color: #5a4a42;
}

/* ==================== 保存按钮 ==================== */
.save-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  background: linear-gradient(135deg, #ff8fa3 0%, #ff6b7a 100%);
  color: #ffffff;
  border: none;
  border-radius: 50rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: 500;
  margin: 40rpx 0 30rpx;
  box-shadow: 0 8rpx 25rpx rgba(255, 107, 122, 0.35);
}

.save-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.btn-icon {
  font-size: 32rpx;
}

/* ==================== 版本信息 ==================== */
.version {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 24rpx;
  color: #bbb;
  padding-bottom: 60rpx;
}

.version-divider {
  color: #ddd;
}

/* 底部留白 - 给自定义 tabBar 留空间 */
.bottom-spacing {
  height: 180rpx;
  width: 100%;
}
