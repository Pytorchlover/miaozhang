/* 设置页面样式 - 治愈可爱风 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #fef9f3 0%, #f5f0eb 100%);
  padding: 24rpx;
  padding-bottom: 120rpx;
  box-sizing: border-box;
}

/* ==================== 小猫吉祥物区域 ==================== */
.mascot-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 30rpx;
}

.mascot-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #5a4a42;
}

/* 猫咪吉祥物容器 */
.cat-mascot {
  position: relative;
  width: 240rpx;
  height: 240rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
  animation: gentleBounce 3s ease-in-out infinite;
}

@keyframes gentleBounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

/* 猫咪身体 */
.cat-body {
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  background: linear-gradient(145deg, #ffffff 0%, #fff5f5 50%, #ffe4e8 100%);
  border-radius: 50%;
  box-shadow: 0 20rpx 60rpx rgba(255, 143, 163, 0.25), inset 0 -10rpx 30rpx rgba(255, 182, 193, 0.3), inset 0 10rpx 30rpx rgba(255, 255, 255, 0.8);
}

/* 猫咪头部 */
.cat-head {
  position: relative;
  width: 160rpx;
  height: 140rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fff8f8 100%);
  border-radius: 50% 50% 45% 45%;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 5rpx 20rpx rgba(0, 0, 0, 0.05);
}

/* 猫咪耳朵 */
.cat-ears {
  position: absolute;
  top: -20rpx;
  width: 160rpx;
  display: flex;
  justify-content: space-between;
}

.cat-ear {
  width: 50rpx;
  height: 50rpx;
  background: linear-gradient(180deg, #fff5f5 0%, #ffe4e8 100%);
  border-radius: 50% 50% 20% 20%;
  transform: rotate(0deg);
  box-shadow: inset 0 5rpx 15rpx rgba(255, 143, 163, 0.3);
}

.cat-ear.left { transform: rotate(-15deg); }
.cat-ear.right { transform: rotate(15deg); }

.cat-ear-inner {
  width: 25rpx;
  height: 25rpx;
  background: linear-gradient(180deg, #ffb6c1 0%, #ff8fa3 100%);
  border-radius: 50% 50% 20% 20%;
  margin: 8rpx auto;
}

.cat-ear.right .cat-ear-inner {
  margin: 8rpx auto;
}

/* 猫咪眼睛 */
.cat-eyes {
  display: flex;
  gap: 35rpx;
  margin-top: 10rpx;
  margin-bottom: 8rpx;
}

.cat-eye {
  width: 28rpx;
  height: 32rpx;
  background: linear-gradient(180deg, #4a4a4a 0%, #2a2a2a 100%);
  border-radius: 50%;
  position: relative;
  animation: blink 4s ease-in-out infinite;
}

.cat-eye::before {
  content: '';
  position: absolute;
  width: 10rpx;
  height: 10rpx;
  background: white;
  border-radius: 50%;
  top: 6rpx;
  left: 5rpx;
}

.cat-eye::after {
  content: '';
  position: absolute;
  width: 5rpx;
  height: 5rpx;
  background: white;
  border-radius: 50%;
  bottom: 8rpx;
  right: 6rpx;
  opacity: 0.6;
}

@keyframes blink {
  0%, 90%, 100% { transform: scaleY(1); }
  95% { transform: scaleY(0.1); }
}

/* 猫咪鼻子和嘴巴 */
.cat-nose {
  width: 12rpx;
  height: 10rpx;
  background: #ffb6c1;
  border-radius: 50% 50% 40% 40%;
  margin-bottom: 4rpx;
}

.cat-mouth {
  width: 30rpx;
  height: 15rpx;
  border-bottom: 3rpx solid #ffb6c1;
  border-radius: 0 0 50% 50%;
}

/* 猫咪腮红 */
.cat-blush {
  position: absolute;
  width: 35rpx;
  height: 20rpx;
  background: rgba(255, 182, 193, 0.5);
  border-radius: 50%;
  top: 65rpx;
}

.cat-blush.left { left: 8rpx; }
.cat-blush.right { right: 8rpx; }

/* 猫咪蝴蝶结 */
.cat-bow {
  position: absolute;
  top: -5rpx;
  right: 15rpx;
  z-index: 3;
}

.cat-bow-center {
  width: 16rpx;
  height: 16rpx;
  background: #ff6b7a;
  border-radius: 50%;
  position: relative;
  z-index: 2;
  box-shadow: 0 2rpx 5rpx rgba(0, 0, 0, 0.1);
}

.cat-bow-left, .cat-bow-right {
  position: absolute;
  width: 24rpx;
  height: 18rpx;
  background: linear-gradient(135deg, #ff8fa3 0%, #ff6b7a 100%);
  border-radius: 50% 50% 50% 50%;
  top: -1rpx;
}

.cat-bow-left {
  right: 14rpx;
  transform: rotate(-20deg);
}

.cat-bow-right {
  left: 14rpx;
  transform: rotate(20deg);
}

/* 猫咪爪子 */
.cat-paws {
  position: absolute;
  bottom: -10rpx;
  display: flex;
  gap: 80rpx;
  z-index: 1;
}

.cat-paw {
  width: 40rpx;
  height: 25rpx;
  background: linear-gradient(180deg, #ffe4e8 0%, #ffd0d8 100%);
  border-radius: 50% 50% 40% 40%;
  box-shadow: 0 3rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* 漂浮装饰元素 */
.floating-elements {
  position: absolute;
  width: 280rpx;
  height: 280rpx;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  pointer-events: none;
}

.floating-coin {
  position: absolute;
  font-size: 32rpx;
  animation: floatCoin 3s ease-in-out infinite;
  filter: drop-shadow(0 5rpx 10rpx rgba(0, 0, 0, 0.1));
}

.coin-1 { top: 5%; right: 5%; animation-delay: 0s; }
.coin-2 { bottom: 15%; left: 0%; animation-delay: 1s; }
.coin-3 { top: 20%; left: 5%; animation-delay: 0.5s; font-size: 26rpx; }

@keyframes floatCoin {
  0%, 100% { transform: translateY(0) rotate(0deg); opacity: 0.9; }
  50% { transform: translateY(-15rpx) rotate(15deg); opacity: 1; }
}

.floating-star {
  position: absolute;
  font-size: 24rpx;
  animation: twinkle 2s ease-in-out infinite;
}

.star-1 { top: 10%; left: 15%; animation-delay: 0.2s; }
.star-2 { bottom: 25%; right: 10%; animation-delay: 0.7s; }
.star-3 { top: 35%; right: 0%; animation-delay: 1.2s; font-size: 20rpx; }

@keyframes twinkle {
  0%, 100% { transform: scale(0.8) rotate(0deg); opacity: 0.5; }
  50% { transform: scale(1.2) rotate(20deg); opacity: 1; }
}

.floating-heart {
  position: absolute;
  font-size: 20rpx;
  animation: heartFloat 4s ease-in-out infinite;
}

.heart-1 { top: 50%; left: 0%; animation-delay: 0s; }
.heart-2 { bottom: 10%; right: 15%; animation-delay: 1.5s; }
.heart-3 { top: 5%; left: 30%; animation-delay: 2.5s; font-size: 16rpx; }

@keyframes heartFloat {
  0%, 100% { transform: translateY(0) scale(1); opacity: 0.6; }
  50% { transform: translateY(-10rpx) scale(1.1); opacity: 0.9; }
}

/* ==================== 区块 ==================== */
.section {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 30rpx rgba(255, 143, 163, 0.12);
}

.section-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.section-emoji {
  font-size: 36rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #5a4a42;
}

/* ==================== 设置卡片 ==================== */
.setting-card {
  background: #fef9f3;
  border-radius: 20rpx;
  padding: 8rpx 20rpx;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5ebe6;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-label-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.setting-icon {
  font-size: 32rpx;
}

.setting-label {
  font-size: 28rpx;
  color: #5a4a42;
}

.setting-input {
  text-align: right;
  font-size: 28rpx;
  color: #5a4a42;
  flex: 1;
  margin-left: 16rpx;
}

.setting-hint {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  font-size: 24rpx;
  color: #9a8a82;
  margin-top: 16rpx;
  line-height: 1.6;
}

.hint-icon {
  font-size: 24rpx;
  flex-shrink: 0;
}

.link {
  color: #ff8fa3;
}

.input-with-unit {
  display: flex;
  align-items: center;
}

.unit {
  font-size: 28rpx;
  color: #9a8a82;
  margin-right: 8rpx;
}

.amount-input {
  text-align: right;
}

/* ==================== 开关按钮 ==================== */
.toggle-btn {
  width: 88rpx;
  height: 48rpx;
  background: #e8e0da;
  border-radius: 24rpx;
  position: relative;
  transition: background 0.3s;
}

.toggle-btn.active {
  background: linear-gradient(135deg, #ff8fa3 0%, #ff6b7a 100%);
}

.toggle-circle {
  width: 40rpx;
  height: 40rpx;
  background: #ffffff;
  border-radius: 50%;
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  transition: transform 0.3s;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.toggle-btn.active .toggle-circle {
  transform: translateX(40rpx);
}

/* ==================== 阈值预览 ==================== */
.threshold-preview {
  margin-top: 24rpx;
  background: linear-gradient(135deg, #fff5f5 0%, #ffe4e8 100%);
  border-radius: 20rpx;
  padding: 24rpx;
}

.threshold-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.threshold-emoji {
  font-size: 28rpx;
}

.threshold-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #ff6b7a;
  flex: 1;
}

.threshold-grid {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
}

.threshold-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 16rpx 8rpx;
}

.threshold-badge {
  width: 40rpx;
  height: 40rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 10rpx;
}

.threshold-badge.daily {
  background: linear-gradient(135deg, #ffb6c1 0%, #ff8fa3 100%);
}

.threshold-badge.weekly {
  background: linear-gradient(135deg, #ffd6cc 0%, #ffb3a0 100%);
}

.threshold-badge.monthly {
  background: linear-gradient(135deg, #ff8fa3 0%, #ff6b7a 100%);
}

.threshold-value {
  font-size: 24rpx;
  font-weight: 600;
  color: #5a4a42;
}

/* ==================== 模式切换 ==================== */
.mode-toggle {
  margin-left: auto;
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #ff8fa3 0%, #ff6b7a 100%);
  border-radius: 30rpx;
  transition: all 0.2s;
}

.mode-toggle:active {
  transform: scale(0.95);
  opacity: 0.9;
}

.mode-text {
  font-size: 22rpx;
  color: #ffffff;
  font-weight: 500;
}

/* ==================== 阈值说明卡片 ==================== */
.threshold-info-card {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-top: 20rpx;
  padding: 20rpx;
  background: linear-gradient(135deg, #fef9f3 0%, #fff5f5 100%);
  border-radius: 16rpx;
  border: 2rpx solid #ffe4e8;
}

.info-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.info-content {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.info-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #5a4a42;
}

.info-desc {
  font-size: 24rpx;
  color: #9a8a82;
  line-height: 1.5;
}

/* ==================== 保存按钮 ==================== */
.save-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  background: linear-gradient(135deg, #ff8fa3 0%, #ff6b7a 100%);
  color: #ffffff;
  border: none;
  border-radius: 50rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: 500;
  margin: 40rpx 0 30rpx;
  box-shadow: 0 8rpx 25rpx rgba(255, 107, 122, 0.35);
}

.save-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.btn-icon {
  font-size: 32rpx;
}

/* ==================== 版本信息 ==================== */
.version {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 24rpx;
  color: #bbb;
  padding-bottom: 60rpx;
}

.version-divider {
  color: #ddd;
}

/* 底部留白 - 给自定义 tabBar 留空间 */
.bottom-spacing {
  height: 180rpx;
  width: 100%;
}
